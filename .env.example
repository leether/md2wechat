# ── 路径配置（必须）──────────────────────────────
# PIPELINE_HOME: 本仓库根目录的绝对路径
# NODE_PATH: Node.js 可执行文件路径（通常直接用 node 即可）

PIPELINE_HOME=/path/to/md2wechat
NODE_PATH=node

# ── 微信公众号凭据（必须）────────────────────────
# 每个公众号账号用 WECHAT_<ACCOUNT>_APP_ID / WECHAT_<ACCOUNT>_APP_SECRET 命名
# <ACCOUNT> 为大写英文，如 MY_ACCOUNT、WORK_ACCOUNT
# 新增账号时添加对应的 key 即可，脚本会按 --account 参数自动匹配

WECHAT_MY_ACCOUNT_APP_ID=your_app_id_here
WECHAT_MY_ACCOUNT_APP_SECRET=your_app_secret_here

# ── 推送环境护栏（可选）─────────────────────────
# 防止在非白名单环境误执行推送脚本（导致 ip_not_in_whitelist 错误）
# 配置后，create_wechat_draft.mjs 会自动拦截非白名单环境的推送请求

# WECHAT_PUBLISH_ALLOWED_HOSTS=my-relay-server,another-host
# WECHAT_PUBLISH_ALLOWED_IPS=1.2.3.4,5.6.7.8
# WECHAT_PUBLISH_FORCE_LOCAL=1   # 仅在本地调试时临时开启，生产环境请删除

# ── 图片生成工具（可选）────────────────────────────
# 配置后，Step 2 会优先用该工具自动生成封面图和正文插图
# 不配置则走手动流程（自行用任何工具准备图片）
#
# 支持的 CLI 工具：
#   Dreamina CLI：IMAGE_GEN_CLI=/path/to/dreamina  IMAGE_GEN_TOOL=dreamina
#   其他 CLI：    IMAGE_GEN_CLI=/path/to/your-tool  IMAGE_GEN_TOOL=custom
#
# Dreamina CLI 参数：
#   IMAGE_GEN_MODEL=5.0          # 模型版本
#   IMAGE_GEN_RATIO=21:9         # 默认比例（封面图）
#   IMAGE_GEN_POLL=120           # 轮询超时秒数

# IMAGE_GEN_CLI=/path/to/dreamina
# IMAGE_GEN_TOOL=dreamina
# IMAGE_GEN_MODEL=5.0
# IMAGE_GEN_RATIO=21:9
# IMAGE_GEN_POLL=120

# ── 文章尾部 CTA + 二维码（可选）────────────────────
# 配置后，渲染器会自动在文章末尾添加 CTA 文案和群二维码
# 不配置则文章无尾部 footer（CTA 护栏会自动降级为警告而非报错）
#
# 命令行参数（--footer-qr 等）优先级高于 .env 配置

# FOOTER_QR_PATH=/path/to/your-qr.png
# FOOTER_CTA=和我们一起探索
# FOOTER_QR_TITLE=交流群
# FOOTER_QR_HINT=扫码加入

# ── Relay 跳板机（可选）─────────────────────────
# 如果微信 IP 白名单限制了你的本地 IP，可以通过 relay 跳板机推送
# 配置后脚本会提示你通过 relay 执行，而不是本地直接推送

# WECHAT_RELAY_HOST=my-relay-server
# WECHAT_RELAY_USER=admin
